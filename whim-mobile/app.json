{
  "expo": {
    "name": "Whim",
    "slug": "whim",
    "scheme": "whim",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "ios": {
      "bundleIdentifier": "com.pranjalrai.whim",
      "supportsTablet": false,
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSLocationWhenInUseUsageDescription": "Whim uses your location to find the closest city and surface spots near you."
      },
      "buildNumber": "4"
    },
    "android": {
      "package": "com.pranjalrai.whim",
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION"
      ],
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#2740E0"
      }
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Whim uses your location to find the closest city and surface spots near you."
        }
      ],
      "expo-notifications",
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash-icon.png",
          "imageWidth": 220,
          "backgroundColor": "#2740E0"
        }
      ]
    ],
    "extra": {
      "router": {}
    },
    "experiments": {
      "typedRoutes": true
    }
  }
}