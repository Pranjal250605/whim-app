{
  "expo": {
    "name": "Whim",
    "slug": "whim",
    "scheme": "whim",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "ios": {
      "bundleIdentifier": "com.whim.app",
      "supportsTablet": false,
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSLocationWhenInUseUsageDescription": "Whim uses your location to find the closest city and surface spots near you."
      }
    },
    "android": {
      "package": "com.whim.app",
      "permissions": ["ACCESS_COARSE_LOCATION", "ACCESS_FINE_LOCATION"]
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Whim uses your location to find the closest city and surface spots near you."
        }
      ],
      "expo-notifications"
    ],
    "extra": {
      "router": {}
    },
    "experiments": {
      "typedRoutes": true
    }
  }
}
