# Copy to .env.seed (gitignored) and fill in, then run:
#   node --env-file=.env.seed scripts/seed-spots.mjs
#
# This file is for the LOCAL admin seeder only. The service-role key here is
# server-side/admin and must never go into the app or get committed.

SUPABASE_URL=https://gvqldgkdtitueyijptmt.supabase.co
SUPABASE_SERVICE_ROLE_KEY=sb_secret_YOUR_ROTATED_SECRET_KEY
MAPBOX_TOKEN=pk.eyJ1IjoicHJhbmphbDI1MDYi... # a token with geocoding access

# Free Pexels photos (https://www.pexels.com/api/). Optional — without it,
# spots keep their tone-colour placeholder. Anchors get photos by default;
# set SEED_NEARBY_PHOTOS=true to also fetch café/nearby photos.
PEXELS_API_KEY=YOUR_PEXELS_API_KEY
# SEED_NEARBY_PHOTOS=false
