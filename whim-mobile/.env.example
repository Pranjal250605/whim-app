# Copy to .env.local and fill in. EXPO_PUBLIC_* vars are inlined into the app at
# build time — only ever put PUBLIC-safe values here (the Supabase anon key is
# safe; the service_role key is NOT and must never appear in this app).

EXPO_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-KEY

# Maps key is used server-side (Edge Function), NOT here. Keep it out of the app.
